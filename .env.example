# ============================================
# ClipAI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ---- Frontend (Vite) ----
VITE_WORKER_URL=http://localhost:5000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- Worker (Flask) ----
FLASK_ENV=production
PORT=5000
CORS_ORIGINS=http://localhost:5173,https://clipai.netlify.app

# ---- JSON2Video API (PAID - primary video processor) ----
JSON2VIDEO_API_KEY=your-json2video-api-key

# ---- Google Gemini (video analysis) ----
GEMINI_API_KEY=your-gemini-api-key

# ---- Groq (caption generation) ----
GROQ_API_KEY=your-groq-api-key

# ---- Paystack (payments - Nigerian Naira) ----
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# ---- Supabase (database + auth) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ---- Cloudflare R2 / Backblaze B2 (video storage) ----
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=clipai-videos
